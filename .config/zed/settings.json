{
  "edit_predictions": {
    "provider": "zed",
  },
  "which_key": {
    "enabled": true,
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-opus-4.6",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "theme": {
    "mode": "system",
    "light": "Alabaster BG",
    "dark": "Alabaster Dark",
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "vim_mode": true,
  "vim": {
    "cursor_shape": {
      "normal": "hollow",
      "insert": "bar",
      "replace": "block",
      "visual": "underline",
    },
    "use_smartcase_find": true,
  },
  "minimap": { "show": "always" },
  "ui_font_family": ".ZedMono",
  "preferred_line_length": 120,
  "ui_font_size": 15,
  "tab_size": 2,
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "buffer_font_size": 15,
  "autosave": "on_focus_change",
  "auto_signature_help": true,
  "show_completions_on_input": true,
  "wrap_guides": [120],
  "relative_line_numbers": "enabled",
  "scroll_beyond_last_line": "one_page",
  "vertical_scroll_margin": 10,
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true,
    },
  },
  "inlay_hints": {
    "enabled": true,
  },
  "collaboration_panel": {
    "button": false,
  },
  "lsp": {
    "metals": {
      "settings": {
        "inlayHints": {
          "inferredTypes": {
            "enable": true,
          },
        },
      },
    },
  },
}
